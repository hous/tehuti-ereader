# Template for local cloud-AI fallback config. Copy this file to `.env` (gitignored) and fill
# in your own key to enable CloudFallbackEngine — without it, the app falls back gracefully to
# "AI features unavailable" wherever on-device Gemini Nano isn't supported (e.g. the emulator).
#
#   cp .env.default .env
#
CLOUD_AI_API_KEY=
CLOUD_AI_MODEL=gemini-2.5-flash
